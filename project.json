{
  "name": "movingday",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/movingday",
        "outputMode": "server",
        "index": "src/index.html",
        "browser": "src/main.ts",
        "server": "src/main.server.ts",
        "ssr": {
          "entry": "src/server.ts"
        },
        "polyfills": ["zone.js"],
        "tsConfig": "tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "public"
          },
          {
            "glob": "**/*",
            "input": "src/assets",
            "output": "assets"
          }
        ],
        "styles": ["src/styles.css"],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1MB",
              "maximumError": "1.3MB"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "src/environments/environment.ts",
              "with": "src/environments/environment.prod.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "build-e2e": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/movingday",
        "outputMode": "server",
        "index": "src/index.html",
        "browser": "src/main.ts",
        "server": "src/main.server.ts",
        "ssr": {
          "entry": "src/server.ts"
        },
        "polyfills": ["zone.js"],
        "tsConfig": "tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "public"
          },
          {
            "glob": "**/*",
            "input": "src/assets",
            "output": "assets"
          }
        ],
        "styles": ["src/styles.css"],
        "scripts": [],
        "optimization": false,
        "extractLicenses": false,
        "sourceMap": true,
        "fileReplacements": [
          {
            "replace": "src/environments/environment.ts",
            "with": "src/environments/environment.e2e.ts"
          }
        ]
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx nx run movingday:build:development",
          "node dist/movingday/server/server.mjs"
        ],
        "parallel": false
      },
      "configurations": {
        "production": {
          "commands": [
            "npx nx run movingday:build:production",
            "node dist/movingday/server/server.mjs"
          ]
        },
        "development": {
          "commands": [
            "npx nx run movingday:build:development",
            "node dist/movingday/server/server.mjs"
          ]
        }
      },
      "defaultConfiguration": "development"
    },
    "serve-e2e": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx nx run movingday:build-e2e",
          "node dist/movingday/server/server.mjs"
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/movingday"],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "{workspaceRoot}/coverage/movingday"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "e2e": {
      "executor": "@nx/cypress:cypress",
      "options": {
        "cypressConfig": "cypress.config.ts",
        "devServerTarget": "movingday:serve-e2e",
        "browser": "chrome",
        "testingType": "e2e"
      },
      "configurations": {
        "production": {
          "devServerTarget": "movingday:serve:production"
        },
        "ci": {
          "ciBaseUrl": "http://localhost:4200"
        }
      }
    }
  }
}
