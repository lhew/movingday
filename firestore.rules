rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Items available for donation
    match /items/{itemId} {
      // Anyone can read items (public showcase)
      allow read: if true;

      // Only authorized users can call dibs
      allow update: if isAuthorizedUser()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'claimedBy', 'claimedAt', 'updatedAt'])
        && request.resource.data.status == 'claimed'
        && resource.data.status == 'available';

      // Only admin can create/delete/fully update items
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Moving updates / blog posts
    match /updates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Agent conversation history
    match /agent-sessions/{sessionId} {
      allow read, write: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read: if request.auth != null;

      // User can update their own doc but NOT the authorized or role fields
      allow update: if request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['authorized', 'role']);

      // Admin or editor can update any user's authorized flag
      allow update: if isAdmin() || hasRole(['editor']);

      // CF admin SDK creates via onCreate trigger
      allow create: if false;
    }

    // Invitations (shareable invite links)
    match /invitations/{inviteId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if false;
    }

    // Nickname reverse-lookup (CF admin SDK only)
    match /nicknames/{nickname} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.token.role == 'admin';
    }

    function hasRole(roles) {
      return request.auth != null && request.auth.token.role in roles;
    }

    function isAuthorizedUser() {
      return request.auth != null && request.auth.token.authorized == true;
    }
  }
}
