    "cypress": "^13.0.0",
    "daisyui": "^5.0.0",
    "esbuild-plugin-istanbul": "^0.3.0",
    "eslint": "^9.0.0",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^13.0.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
