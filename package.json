{
  "name": "movingday",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "start": "nx serve",
    "build": "nx build",
    "test": "nx test",
    "e2e": "nx e2e",
    "lint": "nx lint",
    "format": "nx format:write",
    "affected:test": "nx affected -t test",
    "affected:build": "nx affected -t build",
    "prepare": "husky",
    "emulator:start": "firebase emulators:start --import=.emulator-data --export-on-exit",
    "emulator:start:fresh": "firebase emulators:start",
    "emulator:seed": "node scripts/seed-emulator.mjs",
    "e2e:seed": "node scripts/seed-e2e.mjs",
    "dev": "concurrently \"npm run emulator:start\" \"nx serve\" --names \"firebase,angular\" --prefix-colors \"yellow,cyan\"",
    "bootstrap:admin": "ts-node --esm scripts/bootstrap-admin.ts",
    "stats": "node scripts/generate-stats.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
